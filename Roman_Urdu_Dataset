    "import re\n",
    "\n",
    "def clean_text(text):\n",
    "    text = str(text).lower()\n",
    "    # Fix character repetition (e.g., 'booohat' -> 'boohat')\n",
    "    text = re.sub(r'(.)\\1{2,}', r'\\1\\1', text)\n",
    "    # Clean extra spaces\n",
    "    text = re.sub(r'\\s+', ' ', text).strip()\n",
    "    return text\n",
    "\n",
    "# Safely apply it to the text column\n",
    "df['cleaned_text'] = df['Sentences'].apply(clean_text)\n",
    "\n",
    "# Check a few rows to make sure it looks right\n",
    "print(df[['Sentences', 'cleaned_text']].head())"
   ]
